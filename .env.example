# ----------------------------------------------------------------------------
# PrintVault configuration
# Copy this file to ".env" and adjust the values. Never commit your real .env.
# ----------------------------------------------------------------------------

# Network ---------------------------------------------------------------------
# Port the app listens on (inside the container and on the host).
PORT=8080
# Bind address. 0.0.0.0 is required so the app is reachable over Tailscale.
HOST=0.0.0.0
# Public base URL used when generating share links. Use your Tailscale name/IP.
# Examples: http://100.x.y.z:8080  or  http://your-machine.tailnet-name.ts.net:8080
BASE_URL=http://localhost:8080

# Storage ---------------------------------------------------------------------
# Where uploaded files, the SQLite database and thumbnails live.
# In Docker this is a mounted volume (see docker-compose.yml).
STORAGE_PATH=./data
# Optional explicit DB path. Defaults to <STORAGE_PATH>/printvault.db
# DB_PATH=./data/printvault.db

# Uploads ---------------------------------------------------------------------
# Comma-separated list of allowed file extensions (no spaces).
ALLOWED_EXTENSIONS=stl,3mf,obj,step,stp,gcode,zip,png,jpg,jpeg,webp
# Maximum size per uploaded file, in megabytes.
MAX_UPLOAD_MB=500

# Security --------------------------------------------------------------------
# Secret used to sign session cookies. CHANGE THIS to a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account. Created on first run if no users exist.
# After first login you can change the password from the Settings page.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Set to "production" for production/Docker, "development" for local dev.
NODE_ENV=production
